# Copy to .env and fill in real values:
#   cp .env.example .env        (Linux / macOS)
#   copy .env.example .env      (Windows)

# ── Required ──────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://127.0.0.1:27017/speak-shine
JWT_SECRET=change-me-to-a-long-random-string
JWT_REFRESH_SECRET=change-me-to-another-long-random-string

# ── App ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
API_PORT=3001
FINE_AMOUNT=2

# Comma-separated; optional in development (CORS is open when NODE_ENV != production)
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Redis (optional — in-memory fallback if omitted) ─────────────────────────
# REDIS_URL=redis://127.0.0.1:6379

# ── Cloudflare R2 (required for video upload / analysis) ─────────────────────
R2_ENDPOINT=https://YOUR_ACCOUNT_ID.r2.cloudflarestorage.com
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=https://your-public-r2-domain.com

# ── Groq AI (required for video analysis) ─────────────────────────────────────
GROQ_API_KEY=
# GROQ_API_KEY_2=

# ── LiveKit (optional — live sessions only) ─────────────────────────────────
# LIVEKIT_API_KEY=
# LIVEKIT_API_SECRET=
# LIVEKIT_URL=wss://your-project.livekit.cloud

# ── Feature flags ───────────────────────────────────────────────────────────
ENABLE_VIRUS_SCAN=false
ENABLE_CODEC_VALIDATION=false
ENABLE_CONTENT_MODERATION=false
VIDEO_QUEUE_CONCURRENCY=5
